---
import CTA from "@/sections/CTA.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/service/Header.astro";
import Details from "@/components/service/Details.astro";

const details = [
    "Arena fina y gruesa",
    "Piedra chancada (diferentes medidas)",
    "Hormigón",
    "Afirmado",
    "Tierra de chacra",
    "Nuestras canteras garantizan calidad",
];
---

<Layout
	title="Transporte y venta de agregados en Chiclayo | AyM Corporación"
	description="Venta y transporte de agregados en Chiclayo con canteras y volquetes propios. Arena, piedra chancada y abastecimiento continuo para obras de construcción."
	keywords="transporte de agregados Chiclayo, venta de agregados Chiclayo, arena y piedra chancada Lambayeque, volquetes para obra Chiclayo"
	ogImage="/og.webp"
	ogImageAlt="Transporte de agregados con flota propia en Chiclayo"
>
    <Header image="/services/agregates.webp">
        <Fragment slot="title">
            <span class="block text-white">Venta y Transporte de</span>
            <span class="block text-accent">Agregados</span>
        </Fragment>
        <Fragment slot="subtitle">
            Materiales de construcción de la más alta calidad extraídos de
            canteras propias. Logística eficiente con nuestra flota de volquetes
            para entrega puntual.
        </Fragment>
    </Header>
    <Details
        title="Materiales disponibles"
        subtitle="Agregados"
        items={details}
        image="/services/agregates.webp"
    />
    <CTA />
</Layout>
