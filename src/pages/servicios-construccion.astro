---
import CTA from "@/sections/CTA.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/service/Header.astro";
import Details from "@/components/service/Details.astro";

const details = [
    "Apoyo integral a proyectos de infraestructura",
    "Demolición controlada y limpieza de terreno",
    "Cimentación y obras preliminares",
    "Obras de saneamiento",
    "Pavimentación y asfaltado",
    "Muros de contención",
];
---

<Layout>
    <Header image="/services/building.png">
        <Fragment slot="title">
            <span class="block text-white">Servicios de</span>
            <span class="block text-accent">Construcción</span>
        </Fragment>
        <Fragment slot="subtitle">
            Expertos en obras civiles, desde excavaciones estructurales hasta
            grandes proyectos de infraestructura. Mano de obra especializada y
            maquinaria de última generación a su disposición.
        </Fragment>
    </Header>
    <Details
        title="Servicios principales"
        subtitle="Obras Civiles"
        items={details}
        image="/services/building.png"
    />
    <CTA />
</Layout>
