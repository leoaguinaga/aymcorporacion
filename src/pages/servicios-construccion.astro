---
import CTA from "@/sections/CTA.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/service/Header.astro";
import Details from "@/components/service/Details.astro";

const details = [
    "Apoyo integral a proyectos de infraestructura",
    "Demolición controlada y limpieza de terreno",
    "Cimentación y obras preliminares",
    "Obras de saneamiento",
    "Pavimentación y asfaltado",
    "Muros de contención",
];
---

<Layout
	title="Servicios de construcción en Chiclayo | AyM Corporación"
	description="Servicios de construcción en Chiclayo para obras civiles e infraestructura: demolición, cimentación, saneamiento, pavimentación y muros de contención."
	keywords="servicios de construcción Chiclayo, obras civiles Chiclayo, pavimentación Lambayeque, cimentación y saneamiento Chiclayo"
	ogImage="/og.webp"
	ogImageAlt="Servicios de construcción para infraestructura en Chiclayo"
>
    <Header image="/services/building.webp">
        <Fragment slot="title">
            <span class="block text-white">Servicios de</span>
            <span class="block text-accent">Construcción</span>
        </Fragment>
        <Fragment slot="subtitle">
            Expertos en obras civiles, desde excavaciones estructurales hasta
            grandes proyectos de infraestructura. Mano de obra especializada y
            maquinaria de última generación a su disposición.
        </Fragment>
    </Header>
    <Details
        title="Servicios principales"
        subtitle="Obras Civiles"
        items={details}
        image="/services/building.webp"
    />
    <CTA />
</Layout>
