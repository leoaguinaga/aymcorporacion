---
import CTA from "@/sections/CTA.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/service/Header.astro";
import Details from "@/components/service/Details.astro";

const details = [
    "02 Volquetes Volvo",
    "03 Cisternas Mercedes",
    "01 Motoniveladora 140M",
    "01 Rodillo CAT",
    "01 Cargador Frontal 950H CAT",
];
---

<Layout
	title="Alquiler de maquinaria pesada en Chiclayo | AyM Corporación"
	description="Alquiler de maquinaria pesada en Chiclayo con operadores certificados y disponibilidad inmediata para obras civiles, carreteras y proyectos de infraestructura."
	keywords="alquiler de maquinaria pesada Chiclayo, maquinaria para construcción Chiclayo, volquetes y motoniveladora Lambayeque, equipos con operador certificado"
	ogImage="/og.webp"
	ogImageAlt="Alquiler de maquinaria pesada con operadores certificados en Chiclayo"
>
    <Header image="/services/rent.png">
        <Fragment slot="title">
            <span class="block text-white">Alquiler de</span>
            <span class="block text-accent">Maquinaria pesada</span>
        </Fragment>
        <Fragment slot="subtitle">
            Equipos propios con operador certificado. Disponibilidad inmediata
            para proyectos de construcción, minería y carreteras en todo el
            Perú.
        </Fragment>
    </Header>
    <Details
        title="Equipos disponibles"
        subtitle="Flota"
        items={details}
        image="/services/rent.png"
    />
    <CTA />
</Layout>
