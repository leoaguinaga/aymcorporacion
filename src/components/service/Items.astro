---
const { items } = Astro.props;
---

<div class="py-15">
    <div class="max-w-8xl mx-auto grid grid-cols-4 gap-6">
        {
            items.map((item: any) => (
                <div class="border border-accent bg-accent/10 rounded-lg shadow-md p-6 gap-1 flex flex-col text-center">
                    <h3 class="text-xl font-bold text-black">{item.title}</h3>
                    <p class="text-lg text-black/80">{item.description}</p>
                </div>
            ))
        }
    </div>
</div>
