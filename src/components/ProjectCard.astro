---
import Project from "@/assets/project.jpg";
import Carretera1 from "@/assets/carretera1.jpg";
import Carretera2 from "@/assets/carretera2.jpeg";
import MapPin from "@/assets/icons/map-pin.svg";
import Briefcase from "@/assets/icons/briefcase.svg";
import CircleCheck from "@/assets/icons/circle-check.svg";

interface Props {
    title: string;
    location: string;
    service: string;
    result: string;
}

const { title, location, service, result } = Astro.props;
---

<article
    class="flex flex-col lg:flex-row rounded-xl overflow-hidden shadow-xl w-full"
>
    <img
        src={Project.src}
        alt={`Proyecto ${title} ejecutado por AyM`}
        class="w-full lg:w-1/2 h-[300px] lg:h-auto object-cover"
        loading="lazy"
        decoding="async"
    />
    <div
        class="flex flex-col gap-6 md:gap-8 p-6 md:p-8 w-full lg:w-1/2 bg-white justify-center"
    >
        <div class="flex flex-col gap-4 text-sm md:text-base">
            <h3 class="font-black text-xl md:text-2xl">
                {title}
            </h3>
            <div class="flex flex-row items-start gap-3">
                <MapPin class="size-5 md:size-6 text-accent shrink-0 mt-0.5" />
                <div>
                    <p class="text-gray-700">Ubicación</p>
                    <strong>{location}</strong>
                </div>
            </div>
            <div class="flex flex-row items-start gap-3">
                <Briefcase
                    class="size-5 md:size-6 text-accent shrink-0 mt-0.5"
                />
                <div>
                    <p class="text-gray-700">Servicio</p>
                    <strong>{service}</strong>
                </div>
            </div>
            <div class="flex flex-row items-start gap-3">
                <CircleCheck
                    class="size-5 md:size-6 text-accent shrink-0 mt-0.5"
                />
                <div>
                    <p class="text-gray-700">Resultado</p>
                    <strong>{result}</strong>
                </div>
            </div>
        </div>
        <div
            class="flex items-center justify-between gap-3 md:gap-4 mt-2 lg:mt-0"
        >
            <img
                src={Project.src}
                alt={`Vista del proyecto en ${location}`}
                class="w-[calc(100%/3-8px)] md:w-[calc(100%/3-11px)] h-20 sm:h-28 lg:h-full object-cover rounded-lg"
                loading="lazy"
                decoding="async"
            />
            <img
                src={Carretera1.src}
                alt={`Evidencia de avance de ${service}`}
                class="w-[calc(100%/3-8px)] md:w-[calc(100%/3-11px)] h-20 sm:h-28 lg:h-full object-cover rounded-lg"
                loading="lazy"
                decoding="async"
            />
            <img
                src={Carretera2.src}
                alt={`Resultado final: ${result}`}
                class="w-[calc(100%/3-8px)] md:w-[calc(100%/3-11px)] h-20 sm:h-28 lg:h-full object-cover rounded-lg"
                loading="lazy"
                decoding="async"
            />
        </div>
    </div>
</article>
