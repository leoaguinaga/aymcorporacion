---
import { ContactForm } from "@/components/ContactForm";
---

<section
    class="bg-gray-950 py-16 md:py-20 flex flex-col gap-6 w-full"
    id="contacto"
>
    <div
        class="max-w-8xl mx-auto flex flex-col gap-4 items-center px-6 xl:px-0"
    >
        <h2 class="text-2xl md:text-3xl font-extrabold text-accent">
            Contáctanos
        </h2>
        <h1
            class="uppercase font-black text-3xl md:text-4xl text-center tracking-wide text-white"
        >
            Cotiza tu proyecto hoy
        </h1>
        <p class="text-gray-400 max-w-md text-center text-sm md:text-base">
            Cuéntanos sobre tu proyecto y te responderemos en menos de 24 horas.
        </p>
    </div>
    <ContactForm client:only="react" />
</section>
