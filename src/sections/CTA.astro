---
import { ContactForm } from "@/components/ContactForm";
---

<section class="bg-gray-950 py-20 flex flex-col gap-6">
    <div class="max-w-8xl mx-auto flex flex-col gap-4 items-center">
        <h2 class="text-3xl font-extrabold text-accent">Contáctanos</h2>
        <h1 class="uppercase font-black text-4xl tracking-wide text-white">
            Cotiza tu proyecto hoy
        </h1>
        <p class="text-gray-400 max-w-md text-center">
            Cuéntanos sobre tu proyecto y te responderemos en menos de 24 horas.
        </p>
    </div>
    <ContactForm client:only="react" />
</section>
