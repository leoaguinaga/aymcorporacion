---
import LosPortales from "@/../public/hero/losportales.webp";
import Galilea from "@/../public/hero/logo-galilea.svg";
---

<section
    id="inicio"
    aria-labelledby="hero-title"
    class="flex flex-col lg:flex-row max-w-8xl mx-auto justify-between pt-24 lg:pt-15 pb-10 px-6 xl:px-0 gap-10 lg:gap-8"
>
    <div class="w-full flex flex-col gap-6 lg:gap-4 justify-center lg:py-25">
        <h1
            id="hero-title"
            class="text-4xl lg:text-5xl font-extrabold max-w-2xl leading-tight lg:leading-normal"
        >
            Empresa líder en <span class="text-primary">transporte de agregados</span>, construcción y alquiler de maquinaria pesada en Chiclayo
        </h1>
        <p
            id="hero-description"
            class="text-base lg:text-lg text-gray-600 lg:max-w-164 font-medium"
        >
            Ejecutamos proyectos de infraestructura con maquinaria propia para brindar servicios de construcción, movimiento de tierras y suministro de agregados con entrega directa en obra.
        </p>
        <div
            class="flex flex-col sm:flex-row gap-4 items-stretch sm:items-center"
        >
            <a
                href="#contacto"
                aria-label="Solicitar cotización de transporte de agregados, construcción o alquiler de maquinaria pesada"
                class="bg-primary px-5 py-3 lg:py-2 text-white font-semibold rounded-lg hover:bg-primary/90 text-center text-base lg:text-lg transition-colors duration-300 cursor-pointer"
            >
                Solicitar cotización
            </a>
            <a
                href="#proyectos"
                aria-label="Ver proyectos ejecutados en Chiclayo y Lambayeque"
                class="bg-secondary px-5 py-3 lg:py-2 text-white font-semibold rounded-lg hover:bg-secondary/90 text-center text-base lg:text-lg transition-colors duration-300 cursor-pointer"
            >
                Ver proyectos
            </a>
        </div>
        <div class="flex flex-col gap-6 mt-6 lg:mt-8 w-full lg:pr-10">
            <p
                class="text-lg lg:text-xl text-gray-700 font-bold text-center lg:text-left"
            >
                Somos proveedores de
            </p>
            <div
                class="flex flex-row items-center justify-around lg:justify-start lg:gap-12"
            >
                <img
                    src={LosPortales.src}
                    alt="Los Portales"
                    class="h-12 lg:h-18"
                />
                <img
                    src={Galilea.src}
                    alt="Galilea"
                    class="h-14 lg:h-20 lg:mt-2"
                />
            </div>
        </div>
    </div>
    <div
        class="flex flex-col gap-4 w-full overflow-hidden items-center justify-center"
    >
        <div
            class="relative w-full overflow-hidden rounded-2xl aspect-9/10 max-h-150"
            role="region"
            aria-label="Galería de maquinaria y proyectos"
        >
            <div
                id="hero-track"
                class="flex flex-row h-full transition-transform duration-500 ease-out w-full"
            >
                <img
                    src="/hero/main.webp"
                    alt="Maquinaria pesada de AyM operando en obra de construcción en Chiclayo"
                    class="w-full h-full object-cover shrink-0"
                    loading="eager"
                    decoding="async"
                />
                <img
                    src="/hero/apisonadora.webp"
                    alt="Compactación de terreno con maquinaria propia de AyM"
                    class="w-full h-full object-cover shrink-0"
                    loading="lazy"
                    decoding="async"
                />
                <img
                    src="/hero/rodillo.webp"
                    alt="Rodillo de AyM en proyecto de infraestructura vial"
                    class="w-full h-full object-cover shrink-0"
                    loading="lazy"
                    decoding="async"
                />
            </div>
        </div>
        <div class="flex items-center justify-center gap-1.5 mt-2">
            <button
                data-index="0"
                class="hero-dot w-8 h-2 rounded-full bg-primary transition-all duration-300 cursor-pointer"
                aria-label="Ir a la imagen 1"
                aria-current="true"></button>
            <button
                data-index="1"
                class="hero-dot w-4 h-2 rounded-full bg-secondary transition-all duration-300 cursor-pointer"
                aria-label="Ir a la imagen 2"
                aria-current="false"></button>
            <button
                data-index="2"
                class="hero-dot w-4 h-2 rounded-full bg-secondary transition-all duration-300 cursor-pointer"
                aria-label="Ir a la imagen 3"
                aria-current="false"></button>
        </div>
    </div>
</section>

<script>
    const setupCarousel = () => {
        const track = document.getElementById("hero-track");
        const dots = document.querySelectorAll(".hero-dot");
        if (!track || dots.length === 0) return;

        let currentIndex = 0;
        const totalSlides = dots.length;
        let autoPlayInterval: ReturnType<typeof setInterval>;

        const updateCarousel = (index: number) => {
            currentIndex = index;
            track.style.transform = `translateX(-${index * 100}%)`;

            dots.forEach((dot, i) => {
                if (i === index) {
                    dot.classList.remove("w-4", "bg-secondary");
                    dot.classList.add("w-8", "bg-primary");
                    dot.setAttribute("aria-current", "true");
                } else {
                    dot.classList.remove("w-8", "bg-primary");
                    dot.classList.add("w-4", "bg-secondary");
                    dot.setAttribute("aria-current", "false");
                }
            });
        };

        dots.forEach((dot, index) => {
            dot.addEventListener("click", () => {
                updateCarousel(index);
                resetInterval();
            });
        });

        const nextSlide = () => {
            updateCarousel((currentIndex + 1) % totalSlides);
        };

        const startInterval = () => {
            autoPlayInterval = setInterval(nextSlide, 5000);
        };

        const resetInterval = () => {
            clearInterval(autoPlayInterval);
            startInterval();
        };

        startInterval();
    };

    setupCarousel();
    document.addEventListener("astro:after-swap", setupCarousel);
</script>
