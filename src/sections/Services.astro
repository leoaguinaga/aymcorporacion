---
import ServiceCard from "@/components/ServiceCard.astro";
---

<section
    class="py-20 max-w-8xl mx-auto flex flex-col items-center gap-8 px-15 text-center w-full"
    id="servicios"
>
    <div class="flex flex-col items-center gap-2">
        <h2 class="text-3xl font-extrabold text-primary">Nuestros servicios</h2>
        <h1 class="uppercase font-black text-4xl tracking-wide text-black">
            Soluciones operativas integrales
        </h1>
    </div>
    <div class="grid grid-cols-2 w-full gap-6">
        <ServiceCard />
        <ServiceCard />
        <ServiceCard />
        <ServiceCard />
    </div>
</section>
