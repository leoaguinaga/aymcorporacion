---
import ServiceCard from "@/components/ServiceCard.astro";
import { services } from "@/lib/services.data";
---

<section
    class="py-16 md:py-20 max-w-8xl mx-auto flex flex-col items-center gap-6 md:gap-8 px-6 md:px-15 text-center w-full"
    id="servicios"
>
    <div class="flex flex-col items-center gap-2">
        <h2 class="text-2xl md:text-3xl font-extrabold text-primary">
            Nuestros servicios
        </h2>
        <h1
            class="uppercase font-black text-3xl md:text-4xl tracking-wide text-black"
        >
            Soluciones operativas integrales
        </h1>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 w-full gap-6">
        {
            services.map((service) => (
                <ServiceCard
                    title={service.title}
                    href={service.href}
                    items={service.items}
                    image={service.image}
                />
            ))
        }
    </div>
</section>
