---
import Logo from "@/../public/AYM LOGOS FINALES-02.png";
import { MapPin, Phone, Mail, Clock } from "lucide-react";
---

<footer class="border-t border-[#1f2937] text-black/75 py-8">
    <div class="max-w-8xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
            {/* Opciones Generales */}
            <div class="space-y-4">
                <img src={Logo.src} alt="" class="h-25" />
                <p class="text-sm leading-relaxed">
                    Especialistas en alquiler de maquinaria pesada, venta de
                    agregados y ejecución de proyectos de infraestructura en
                    todo el Perú.
                </p>
            </div>

            {/* Enlaces Rápidos */}
            <div class="space-y-4">
                <h4 class="text-black text-lg font-bold">Enlaces Rápidos</h4>
                <ul class="space-y-2">
                    <li>
                        <a
                            href="#nosotros"
                            class="hover:text-accent transition-colors"
                            >Nosotros</a
                        >
                    </li>
                    <li>
                        <a
                            href="#servicios"
                            class="hover:text-accent transition-colors"
                            >Servicios</a
                        >
                    </li>
                    <li>
                        <a
                            href="#proyectos"
                            class="hover:text-accent transition-colors"
                            >Proceso</a
                        >
                    </li>
                    <li>
                        <a
                            href="#flota"
                            class="hover:text-accent transition-colors">Flota</a
                        >
                    </li>
                    <li>
                        <a
                            href="#proyectos"
                            class="hover:text-accent transition-colors"
                            >Proyectos</a
                        >
                    </li>
                </ul>
            </div>

            {/* Servicios */}
            <div class="space-y-4">
                <h4 class="text-black text-lg font-bold">Nuestros Servicios</h4>
                <ul class="space-y-2">
                    <li>
                        <a href="#" class="hover:text-accent transition-colors"
                            >Movimiento de Tierras</a
                        >
                    </li>
                    <li>
                        <a href="#" class="hover:text-accent transition-colors"
                            >Alquiler de Maquinaria</a
                        >
                    </li>
                    <li>
                        <a href="#" class="hover:text-accent transition-colors"
                            >Obras Civiles</a
                        >
                    </li>
                    <li>
                        <a href="#" class="hover:text-accent transition-colors"
                            >Venta de Agregados</a
                        >
                    </li>
                </ul>
            </div>

            <div class="space-y-4">
                <h4 class="text-black text-lg font-bold">Contacto</h4>
                <ul class="space-y-2">
                    <li class="flex items-start gap-3">
                        <MapPin
                            className="w-5 h-5 text-accent shrink-0 mt-0.5"
                        />
                        <span class="text-sm"
                            >Carretera Chiclayo, Lambayeque</span
                        >
                    </li>
                    <li class="flex items-center gap-3">
                        <Phone className="w-5 h-5 text-accent shrink-0" />
                        <span class="text-sm">+51 987 654 321</span>
                    </li>
                    <li class="flex items-center gap-3">
                        <Mail className="w-5 h-5 text-accent shrink-0" />
                        <span class="text-sm">contacto@aymcorporacion.com</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <Clock
                            className="w-5 h-5 text-accent shrink-0 mt-0.5"
                        />
                        <span class="text-sm"
                            >Lunes - Viernes: 8:00 AM - 6:00 PM<br />Sábados:
                            8:00 AM - 1:00 PM</span
                        >
                    </li>
                </ul>
            </div>
        </div>
    </div>
</footer>
