---
import ChevronLeft from "@/assets/icons/chevron-left.svg";
import ChevronRight from "@/assets/icons/chevron-right.svg";
import ProjectCard from "@/components/ProjectCard.astro";
---

<section class="bg-gray-200 py-16 md:py-20" id="proyectos">
    <div
        class="max-w-8xl mx-auto flex flex-col gap-6 md:gap-4 w-full px-6 xl:px-0"
    >
        <div class="flex flex-col gap-2">
            <div
                class="w-full flex flex-col md:flex-row items-start md:items-center justify-between gap-6 md:gap-0"
            >
                <div class="flex flex-col items-start gap-2">
                    <h2
                        class="text-2xl md:text-3xl font-extrabold text-primary"
                    >
                        Proyectos destacados
                    </h2>
                    <h1
                        class="uppercase font-black text-3xl md:text-4xl max-w-lg tracking-wide text-black"
                    >
                        Resultados que hablan por sí solos
                    </h1>
                </div>
                <div class="flex items-center gap-2 self-end md:self-auto">
                    <button
                        class="flex items-center justify-center rounded-full bg-primary text-white p-2 hover:bg-primary/90 transition-colors"
                    >
                        <ChevronLeft class="size-6" />
                    </button>
                    <button
                        class="flex items-center justify-center rounded-full bg-primary text-white p-2 hover:bg-primary/90 transition-colors"
                    >
                        <ChevronRight class="size-6" />
                    </button>
                </div>
            </div>
        </div>
        <div
            class="flex flex-col mt-4 md:mt-4 items-center justify-between gap-4"
        >
            <ProjectCard />
        </div>
    </div>
</section>
