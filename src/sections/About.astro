---
import {
    Target,
    Eye,
    Handshake,
    ShieldCheck,
    Award,
    Zap,
    UserCheck,
    Lightbulb,
} from "lucide-react";
---

<section class="bg-gray-100 py-16 md:py-24" id="nosotros">
    <div class="max-w-8xl mx-auto px-6 xl:px-0 flex flex-col gap-16">
        <div
            class="text-center max-w-3xl mx-auto flex flex-col items-center gap-4"
        >
            <h2
                class="text-3xl md:text-5xl font-extrabold text-primary tracking-tight"
            >
                Nuestra Esencia
            </h2>
            <p class="text-gray-600 text-lg md:text-xl font-medium mt-2">
                Impulsamos el desarrollo de infraestructura en Chiclayo con
                capacidad operativa, maquinaria propia y un enfoque
                inquebrantable en la solidez de cada proyecto.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
            <!-- Misión y Visión -->
            <div class="lg:col-span-7 flex flex-col gap-8 h-full">
                <!-- Misión Card -->
                <div
                    class="bg-white p-8 md:p-10 rounded-2xl shadow-xl shadow-gray-200/40 border border-gray-100 flex-1 relative overflow-hidden group"
                >
                    <div
                        class="absolute top-0 right-0 w-40 h-40 bg-primary/5 rounded-bl-[100px] z-0 transition-transform duration-500 group-hover:scale-125"
                    >
                    </div>
                    <div class="flex items-center gap-4 mb-6 relative z-10">
                        <div
                            class="p-3.5 bg-primary/10 rounded-xl text-primary"
                        >
                            <Target className="w-8 h-8" />
                        </div>
                        <h3
                            class="text-2xl md:text-3xl font-black text-gray-900 uppercase tracking-wide"
                        >
                            Misión
                        </h3>
                    </div>
                    <p
                        class="text-gray-600 leading-relaxed relative z-10 text-base md:text-xl"
                    >
                        Brindar soluciones integrales para proyectos de
                        construcción mediante el alquiler de maquinaria pesada,
                        servicios especializados y suministro de agregados de
                        alta calidad, garantizando <strong
                            class="text-primary font-bold"
                            >eficiencia, seguridad y cumplimiento</strong
                        > en cada obra.
                    </p>
                </div>

                <!-- Visión Card -->
                <div
                    class="bg-gray-950 p-8 md:p-10 rounded-2xl shadow-xl shadow-gray-900/20 flex-1 relative overflow-hidden group text-white"
                >
                    <div
                        class="absolute top-0 right-0 w-40 h-40 bg-accent/10 rounded-bl-[100px] z-0 transition-transform duration-500 group-hover:scale-125"
                    >
                    </div>
                    <div class="flex items-center gap-4 mb-6 relative z-10">
                        <div class="p-3.5 bg-accent/20 rounded-xl text-accent">
                            <Eye className="w-8 h-8" />
                        </div>
                        <h3
                            class="text-2xl md:text-3xl font-black uppercase tracking-wide"
                        >
                            Visión
                        </h3>
                    </div>
                    <p
                        class="text-gray-300 leading-relaxed relative z-10 text-base md:text-xl"
                    >
                        Ser una empresa referente en el desarrollo de
                        infraestructura en el Perú, reconocida por nuestra <strong
                            class="text-white font-bold bg-white/10 px-1.5 py-0.5 rounded"
                            >capacidad operativa, maquinaria propia y suministro
                            confiable</strong
                        > de agregados.
                    </p>
                </div>
            </div>

            <!-- Valores -->
            <div class="lg:col-span-5 flex flex-col">
                <div class="mb-6 lg:mb-8 text-center lg:text-left">
                    <h3
                        class="text-2xl md:text-3xl font-black text-gray-900 uppercase tracking-wide"
                    >
                        Nuestros Valores
                    </h3>
                </div>
                <div class="grid grid-cols-2 gap-4 md:gap-5 h-full">
                    <div
                        class="bg-white p-5 md:p-6 rounded-2xl shadow-lg shadow-gray-200/30 border border-gray-100 flex flex-col items-center lg:items-start text-center lg:text-left gap-3 hover:-translate-y-1 transition-transform duration-300"
                    >
                        <div class="p-3 bg-gray-50 text-primary rounded-xl">
                            <Handshake className="w-6 h-6" />
                        </div>
                        <h4 class="font-bold text-gray-900 text-lg">
                            Compromiso
                        </h4>
                    </div>

                    <div
                        class="bg-white p-5 md:p-6 rounded-2xl shadow-lg shadow-gray-200/30 border border-gray-100 flex flex-col items-center lg:items-start text-center lg:text-left gap-3 hover:-translate-y-1 transition-transform duration-300"
                    >
                        <div class="p-3 bg-gray-50 text-primary rounded-xl">
                            <ShieldCheck className="w-6 h-6" />
                        </div>
                        <h4 class="font-bold text-gray-900 text-lg">
                            Seguridad
                        </h4>
                    </div>

                    <div
                        class="bg-white p-5 md:p-6 rounded-2xl shadow-lg shadow-gray-200/30 border border-gray-100 flex flex-col items-center lg:items-start text-center lg:text-left gap-3 hover:-translate-y-1 transition-transform duration-300"
                    >
                        <div class="p-3 bg-gray-50 text-primary rounded-xl">
                            <Award className="w-6 h-6" />
                        </div>
                        <h4 class="font-bold text-gray-900 text-lg">Calidad</h4>
                    </div>

                    <div
                        class="bg-white p-5 md:p-6 rounded-2xl shadow-lg shadow-gray-200/30 border border-gray-100 flex flex-col items-center lg:items-start text-center lg:text-left gap-3 hover:-translate-y-1 transition-transform duration-300"
                    >
                        <div class="p-3 bg-gray-50 text-primary rounded-xl">
                            <Zap className="w-6 h-6" />
                        </div>
                        <h4 class="font-bold text-gray-900 text-lg">
                            Eficiencia
                        </h4>
                    </div>

                    <div
                        class="bg-white p-5 md:p-6 rounded-2xl shadow-lg shadow-gray-200/30 border border-gray-100 flex flex-col items-center lg:items-start text-center lg:text-left gap-3 hover:-translate-y-1 transition-transform duration-300"
                    >
                        <div class="p-3 bg-gray-50 text-primary rounded-xl">
                            <UserCheck className="w-6 h-6" />
                        </div>
                        <h4 class="font-bold text-gray-900 text-lg">
                            Responsabilidad
                        </h4>
                    </div>

                    <div
                        class="bg-white p-5 md:p-6 rounded-2xl shadow-lg shadow-gray-200/30 border border-gray-100 flex flex-col items-center lg:items-start text-center lg:text-left gap-3 hover:-translate-y-1 transition-transform duration-300"
                    >
                        <div class="p-3 bg-gray-50 text-primary rounded-xl">
                            <Lightbulb className="w-6 h-6" />
                        </div>
                        <h4 class="font-bold text-gray-900 text-lg">
                            Innovación
                        </h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
