---
import { FAQAccordion } from "@/components/FAQAccordion";
---

<section class="bg-gray-50 py-16 md:py-24" id="faq">
    <div class="max-w-8xl mx-auto px-6 xl:px-0 flex flex-col gap-10 lg:gap-14">
        <div
            class="flex flex-col gap-2 max-w-3xl mx-auto text-center items-center"
        >
            <h2 class="text-2xl md:text-3xl font-extrabold text-primary">
                Preguntas Frecuentes
            </h2>
            <h1
                class="uppercase font-black text-3xl md:text-4xl tracking-wide text-black"
            >
                Resolvemos tus dudas
            </h1>
            <p class="text-gray-600 text-base md:text-lg font-medium mt-2">
                Encuentra respuestas rápidas sobre nuestros servicios,
                coberturas y modalidades de trabajo con maquinaria propia.
            </p>
        </div>

        <FAQAccordion client:load />
    </div>
</section>
